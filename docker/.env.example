PROVIDER_API_KEY=your_api_key_here
CHAT_COMPLETIONS_URL=https://api.openai.com/v1/chat/completions
MODEL=gpt-4o

BRIDGE_USER=admin
BRIDGE_PASS=password

# Make files created in ./workspace belong to the host user instead of root.
# On Linux, set these to the output of: id -u and id -g
HOST_UID=1000
HOST_GID=1000

# Optional extra style guidance. The bridge always keeps its built-in
# AltanAI file-edit protocol and appends this text after it.
SYSTEM_INSTRUCTION=Answer plainly in short paragraphs for a Mac OS 9 plain text code client. Do not use Markdown tables, ASCII art, emojis, or roleplay unless the user asks.
REQUEST_TIMEOUT=90
MAX_COMPLETION_TOKENS=4096

# Optional: enables the Mac OS 9 client's Build button.
# The command runs inside /app/workspace in the bridge container.
BUILD_COMMAND=
BUILD_TIMEOUT=120
BUILD_OUTPUT=
BUILD_PROJECT_DIR=

# For a Retro68-enabled Linux host, mount the toolchain and set:
# RETRO68_HOST_ROOT=/opt/retro68/toolchain
# RETRO68_ROOT=/opt/retro68/toolchain
# BUILD_COMMAND=/app/build_macos9.sh
# BUILD_PROJECT_DIR=macos9_client
# BUILD_OUTPUT=

# Optional: mount ../os9docs-master into the container for API snippets.
OS9_DOCS_ROOT=/app/os9docs-master
MAX_DOC_SNIPPETS=4
